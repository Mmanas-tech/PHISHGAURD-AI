# =============================================================================
# PhishGuard AI — Environment Variables
# Copy to .env and fill in real values
# =============================================================================

# ---- Application ----
APP_NAME=PhishGuard AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-64-char-string

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+asyncpg://phishguard:phishguard_secret@postgres:5432/phishguard_db
POSTGRES_USER=phishguard
POSTGRES_PASSWORD=phishguard_secret
POSTGRES_DB=phishguard_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300

# ---- JWT Auth ----
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- OpenAI (GPT-4o) ----
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT=3

# ---- VirusTotal ----
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here
VIRUSTOTAL_API_URL=https://www.virustotal.com/api/v3

# ---- AI Engine ----
AI_ENGINE_URL=http://ai-engine:8001
AI_ENGINE_TIMEOUT=5

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","chrome-extension://*"]

# ---- Rate Limiting ----
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Monitoring ----
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# ---- Extension ----
EXTENSION_API_URL=http://localhost:8000
